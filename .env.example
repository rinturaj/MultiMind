# OpenAI Configuration
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4-turbo-preview
OPENAI_TEMPERATURE=0.7
OPENAI_MAX_TOKENS=4096

# Application Configuration
APP_NAME=RepoMesh AI
APP_VERSION=0.1.0
APP_ENV=development
DEBUG=true
LOG_LEVEL=INFO

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true
API_WORKERS=1

# Repository Configuration
REPOS_BASE_PATH=./repos
MAX_REPO_SIZE_MB=500
CLONE_TIMEOUT_SECONDS=300

# ChromaDB Configuration
CHROMA_PERSIST_DIRECTORY=./data/chroma
CHROMA_COLLECTION_NAME=repomesh_context
CHROMA_EMBEDDING_MODEL=text-embedding-ada-002

# Agent Configuration
MAX_CONCURRENT_AGENTS=5
AGENT_TIMEOUT_SECONDS=300
AGENT_RETRY_ATTEMPTS=3

# Orchestration Configuration
MAX_ORCHESTRATION_STEPS=50
ORCHESTRATION_TIMEOUT_SECONDS=600

# Event System Configuration
EVENT_HISTORY_MAX_SIZE=1000
EVENT_RETENTION_HOURS=24

# Context Configuration
CONTEXT_SEARCH_TOP_K=10
CONTEXT_SIMILARITY_THRESHOLD=0.7

# Security Configuration
CORS_ORIGINS=["http://localhost:3000", "http://localhost:8000"]
CORS_ALLOW_CREDENTIALS=true
CORS_ALLOW_METHODS=["*"]
CORS_ALLOW_HEADERS=["*"]

# Monitoring Configuration
ENABLE_TRACING=true
TRACE_OUTPUT_DIR=./traces
ENABLE_METRICS=true